# Copy to .env and fill in. Pick ONE provider — set LLM_PROVIDER accordingly.

# --- LLM provider selector ---
# Options: "groq" (free tier, default) | "anthropic" (paid)
LLM_PROVIDER=groq

# --- Groq (free tier; get a key at https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic (paid; get a key at https://console.anthropic.com/) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_ROUTER_MODEL=claude-haiku-4-5-20251001

# --- Local paths ---
CHROMA_PERSIST_DIR=./data/chroma_store
EVAL_OUTPUT_DIR=./eval_runs

# --- Logging ---
LOG_LEVEL=INFO
